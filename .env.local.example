# Supabase (Whipz.AI project — ap-southeast-1/Singapore)
NEXT_PUBLIC_SUPABASE_URL=https://qeukrllotwhrprfyspiq.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable__86h2cCAk9gxUNwqLKJC1g_qZ4tI7ef
SUPABASE_URL=https://qeukrllotwhrprfyspiq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App-level encryption for tenants.llm_api_key_enc (BYOK keys).
# Generate with: openssl rand -base64 32
TENANT_KEY_ENCRYPTION_SECRET=your-32-byte-base64-secret

# Every tenant brings their own Qwen/DashScope key (set per-tenant in
# Settings) — there's no platform-hosted key, so no API key belongs
# here. DASHSCOPE_BASE_URL is shared config (may be a dedicated
# workspace domain, e.g. https://{workspaceId}.{region}.maas.aliyuncs.com/compatible-mode/v1).
# QWEN_MODEL/QWEN_EMBEDDING_MODEL are just fallback defaults used when
# a tenant hasn't set llm_model.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Public base URL this app is reachable at — used to build exact OAuth
# redirect URIs for channel connections. Must match what's registered
# in each platform's console. While testing locally with a tunnel
# (ngrok/cloudflared), set this to the tunnel's https URL.
APP_BASE_URL=https://your-tunnel-or-domain.example.com

# Facebook Messenger + Instagram (same Meta App/OAuth app — Meta Login
# for Business). Create at developers.facebook.com. Messenger/Instagram
# messaging require Meta App Review before real (non-admin) users can
# message the connected Page/Account.
META_APP_ID=
META_APP_SECRET=
# Any string you choose — also entered as the "Verify Token" when
# configuring the webhook URL in the Meta App dashboard.
META_WEBHOOK_VERIFY_TOKEN=

# LINE Messaging API channel — created per-business in LINE Developers
# Console (no OAuth redirect; Channel ID/Secret/Access Token are
# entered directly on the Channels page instead of env vars, since
# each tenant has their own LINE channel).

# TikTok Shop Partner app — created in TikTok Shop Partner Center.
# Least standardized of the four; endpoints in lib/channels/tiktok.ts
# are best-effort and may need adjusting once you have partner docs access.
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
